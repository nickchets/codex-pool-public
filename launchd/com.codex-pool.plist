<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.codex-pool</string>
  <key>ProgramArguments</key>
  <array>
    <string>__CODEX_POOL_BIN__</string>
    <string>--pool-dir</string>
    <string>__CODEX_POOL_WORKDIR__/pool</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__CODEX_POOL_WORKDIR__</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>__CODEX_POOL_WORKDIR__/codex-pool.out.log</string>
  <key>StandardErrorPath</key>
  <string>__CODEX_POOL_WORKDIR__/codex-pool.err.log</string>
</dict>
</plist>
