# Codex Pool Proxy Configuration
# Copy this file to config.toml and customize as needed.
# Environment variables take precedence over config file values.

# Server settings
listen_addr = "127.0.0.1:8989"
pool_dir = "pool"
db_path = "./data/proxy.db"
max_attempts = 3
force_codex_required_plan = ""
disable_refresh = false
debug = false
# Max request body size to buffer in memory before streaming (bytes).
# Set via env PROXY_MAX_INMEM_BODY_BYTES (default 16777216).

# Public URL for generated configs and instructions
# Use this when behind a reverse proxy or using a custom domain
# Example: "https://proxy.example.com" or "http://192.168.1.100:8989"
public_url = ""

# Optional: force all pooled Codex traffic handled by this runtime onto one plan.
# Intended for a dedicated GitLab Codex sidecar runtime.
# Example: "gitlab_duo"
# force_codex_required_plan = "gitlab_duo"

# Optional: candidate model slugs for GitLab Codex sidecar discovery.
# When force_codex_required_plan = "gitlab_duo", /backend-api/codex/models can
# probe this list against GitLab direct-access and publish only working models.
# gitlab_codex_discovery_models = "gpt-5-codex,gpt-5.3-codex,gpt-5.2-codex,gpt-5,gpt-5.4-mini,gpt-5.4-nano"

# Friend Code Access
# Enable a self-service landing page at / where users with this code
# can generate their own credentials.
friend_code = ""

# Pool Users (Multi-User Mode)
# Enable this section to allow creating users who can share the pool
# without access to real account credentials.
[pool_users]
# Password for the admin UI at /admin/pool-users
admin_password = ""

# Secret key for signing pool user tokens (should be 32+ characters)
jwt_secret = ""

# Where to store pool user data
storage_path = "./data/pool_users.json"
