listen_addr = "127.0.0.1:8989"
pool_dir = "pool"

# Set this when reverse-proxying or serving beyond loopback.
# public_url = "https://codex-pool.example.com"

# Required for remote operator API calls. Loopback operator use does not need it.
# admin_token = "replace-with-a-long-random-token"

# Optional: require clients to send X-Codex-Pool-Token on proxied Codex requests.
# shared_proxy_token = "replace-with-a-long-random-token"

max_attempts = 3
request_timeout_seconds = 300
stream_idle_timeout_seconds = 600

upstream_codex_base = "https://chatgpt.com/backend-api/codex"
upstream_backend_base = "https://chatgpt.com/backend-api"
upstream_openai_api_base = "https://api.openai.com"
upstream_auth_base = "https://auth.openai.com"
